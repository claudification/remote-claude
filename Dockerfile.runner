# claudewerk/claudewerk-runner
#
# Sandboxed Docker image for running Claude Code with the claudewerk agent host.
# Includes: CC, rclaude, sentinel, opencode-host, bun, python3, gh, ripgrep, build-essential, neovim.
#
# Build:
#   bun run build:linux
#   docker build -f Dockerfile.runner -t claudewerk/claudewerk-runner .
#
# Run:
#   docker run --rm -it \
#     -e ANTHROPIC_API_KEY \
#     -e CLAUDWERK_BROKER=ws://host.docker.internal:9999 \
#     -e CLAUDWERK_SENTINEL_SECRET=your-secret \
#     -v $(pwd):/workspace/project \
#     claudewerk/claudewerk-runner

FROM debian:bookworm-slim

LABEL org.opencontainers.image.source="https://github.com/claudewerk/claudewerk-runner"
LABEL org.opencontainers.image.description="Docker image for running Claude Code with the claudewerk agent host"
LABEL org.opencontainers.image.licenses="MIT"

ARG USER_UID=1000
ARG USER_GID=1000

# System deps (CC brings its own Node via native installer)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates git jq procps tmux openssh-client sudo \
    python3 python3-pip python3-venv \
    build-essential \
    ripgrep fd-find \
    wget unzip zip \
    less tree sqlite3 neovim \
    && ln -sf /usr/bin/fdfind /usr/local/bin/fd \
    && rm -rf /var/lib/apt/lists/*

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# gosu for dynamic UID/GID drop in entrypoint (pre-built, no compiler needed)
ARG GOSU_VERSION=1.17
RUN arch=$(dpkg --print-architecture) \
    && curl -fsSL "https://github.com/tianon/gosu/releases/download/${GOSU_VERSION}/gosu-${arch}" -o /usr/local/bin/gosu \
    && chmod +x /usr/local/bin/gosu \
    && gosu --version

# Non-root user (entrypoint may remap UID/GID)
RUN groupadd -g ${USER_GID} claude \
    && useradd -m -u ${USER_UID} -g claude -s /bin/bash claude \
    && echo "claude ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/claude \
    && mkdir -p /home/claude/.claude /workspace \
    && chown -R claude:claude /home/claude /workspace

# Git safe.directory for mounted workspaces
RUN git config --system --add safe.directory '*'

# Bun (JS/TS runtime)
USER claude
RUN curl -fsSL https://bun.sh/install | bash
USER root
ENV PATH="/home/claude/.bun/bin:${PATH}"

# Claude Code via native installer
USER claude
RUN curl -fsSL https://claude.ai/install.sh | bash
USER root
ENV PATH="/home/claude/.local/bin:${PATH}"

# claudewerk agent hosts + satellite tools (from npm, runs under bun)
USER claude
RUN bun add -g @claudewerk/claude-agent-host @claudewerk/sentinel @claudewerk/opencode-agent-host opencode-ai
USER root

# Entrypoint
COPY docker/runner-entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["sentinel"]
