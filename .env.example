# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  CONCENTRATOR - Docker Deployment Configuration                            │
# │                                                                            │
# │  Copy this file to .env and edit to match your setup:                      │
# │    cp .env.example .env                                                    │
# │                                                                            │
# │  Then start with:                                                          │
# │    docker compose up -d                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Claude Transcripts ────────────────────────────────────────────────────────
#
# Path to the .claude directory on the Docker HOST machine.
# Mounted read-only into the container at /data/transcripts.
# This is where Claude Code stores session transcripts (JSONL files).
#
# The concentrator reads these to show conversation history in the dashboard.
# If running on a different machine than Claude Code, you'll need to sync
# or mount this directory from wherever Claude Code is running.
#
CLAUDE_DIR=~/.claude

# ── WebAuthn / Passkey Authentication ─────────────────────────────────────────
#
# RP_ID = Relying Party ID. This is your domain name WITHOUT protocol.
# Must match exactly what the browser sees. Cannot be changed after
# passkeys are registered (they're bound to this value).
#
#   Local dev:  localhost
#   Production: concentrator.example.com
#
RP_ID=localhost

# ORIGIN = The full URL origin the browser uses to access the dashboard.
# Must include protocol. Must match what's in the browser address bar.
# Multiple origins can be set by adding more --origin flags in compose command.
#
#   Local dev:  http://localhost:9999
#   Production: https://concentrator.example.com
#
ORIGIN=http://localhost:9999

# ── Caddy Reverse Proxy (caddy-docker-proxy) ─────────────────────────────────
#
# If you're using caddy-docker-proxy, set CADDY_HOST to your domain.
# The compose file includes labels that Caddy picks up automatically:
#   - Reverse proxy to port 9999
#   - TLS via Cloudflare DNS challenge (uses tls_cloudflare snippet)
#
# Leave empty to skip Caddy integration (e.g. for local dev or other proxies).
#
# The container must be on the 'caddy' Docker network:
#   docker network create caddy  (if it doesn't exist)
#
CADDY_HOST=

# ── How It All Fits Together ──────────────────────────────────────────────────
#
# 1. Start the concentrator:
#      docker compose up -d
#
# 2. Create your first passkey (run INSIDE the container):
#      docker exec concentrator concentrator-cli create-invite \
#        --name yourname \
#        --url https://your-domain.example
#
#    This prints a one-time invite link (expires in 30 minutes).
#    Open it in your browser to register your passkey.
#
# 3. On machines running Claude Code, use rclaude instead of claude:
#      rclaude --concentrator ws://your-server:9999
#
#    Or if behind Caddy with TLS:
#      rclaude --concentrator wss://concentrator.example.com
#
#    Note: rclaude -> concentrator is the HOOK EVENT stream (WebSocket).
#    This does NOT require authentication -- it's internal plumbing.
#    Only the web dashboard requires passkey auth.
#
# 4. Open the dashboard in your browser:
#      https://concentrator.example.com
#
# 5. Manage users:
#      docker exec concentrator concentrator-cli list-users
#      docker exec concentrator concentrator-cli revoke --name badactor
#
# ── Port Reference ────────────────────────────────────────────────────────────
#
#   9999  Concentrator (WebSocket + REST API + Dashboard)
#         - rclaude connects here via WebSocket
#         - Browser connects here for the dashboard
#         - Both share the same port
#
#   If you need to change the port, add to docker-compose command:
#     command: ["--port", "8080", ...]
#   And update ORIGIN accordingly.
#
# ── Volumes ───────────────────────────────────────────────────────────────────
#
#   concentrator-data  Named volume for session cache + auth state.
#                      Contains auth.json (passkey credentials),
#                      auth.secret (HMAC signing key), and
#                      session cache. Back this up!
#
#   $CLAUDE_DIR        Bind mount (read-only) for Claude transcripts.
#                      Only needed for the transcript viewer tab.
#                      Everything else works without it.
