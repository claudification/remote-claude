# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  CONCENTRATOR - Docker Deployment Configuration                            │
# │                                                                            │
# │  Copy this file to .env and edit to match your setup:                      │
# │    cp .env.example .env                                                    │
# │                                                                            │
# │  Then start with:                                                          │
# │    docker compose up -d                                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Shared Secret ─────────────────────────────────────────────────────────────
#
# Shared secret between rclaude and concentrator for WebSocket authentication.
# Generate with: openssl rand -hex 32
#
# rclaude sends this on connect. Concentrator rejects connections without it.
#
RCLAUDE_SECRET=

# ── WebAuthn / Passkey Authentication ─────────────────────────────────────────
#
# RP_ID = Relying Party ID. This is your domain name WITHOUT protocol.
# Must match exactly what the browser sees. Cannot be changed after
# passkeys are registered (they're bound to this value).
#
#   Local dev:  localhost
#   Production: concentrator.example.com
#
RP_ID=localhost

# ORIGIN = The full URL origin the browser uses to access the dashboard.
# Must include protocol. Must match what's in the browser address bar.
# Multiple origins can be set by adding more --origin flags in compose command.
#
#   Local dev:  http://localhost:9999
#   Production: https://concentrator.example.com
#
ORIGIN=http://localhost:9999

# ── External Port ─────────────────────────────────────────────────────────────
#
# Port exposed on the Docker host for the concentrator.
#
PORT=9999

# ── Caddy Reverse Proxy (caddy-docker-proxy) ─────────────────────────────────
#
# If you're using caddy-docker-proxy, set CADDY_HOST to your domain.
# The docker-compose.yml includes labels that Caddy picks up automatically.
#
# Leave empty for local dev or when using a different reverse proxy.
#
CADDY_HOST=

# ── Push Notifications (optional) ────────────────────────────────────────────
#
# VAPID keys for Web Push notifications.
# Generate with: npx web-push generate-vapid-keys
#
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ── How It All Fits Together ──────────────────────────────────────────────────
#
# 1. Generate a secret:
#      echo "RCLAUDE_SECRET=$(openssl rand -hex 32)" >> .env
#
# 2. Start the concentrator:
#      docker compose up -d
#
# 3. Create your first passkey (run INSIDE the container):
#      docker exec concentrator concentrator-cli create-invite \
#        --name yourname \
#        --url https://your-domain.example
#
#    This prints a one-time invite link (expires in 30 minutes).
#    Open it in your browser to register your passkey.
#
# 4. On machines running Claude Code, set in your shell:
#      export RCLAUDE_SECRET="<same secret as above>"
#      export RCLAUDE_CONCENTRATOR="wss://concentrator.example.com"
#
#    Then use rclaude instead of claude:
#      rclaude
#
# 5. Open the dashboard:
#      https://concentrator.example.com
#
# ── Volumes ───────────────────────────────────────────────────────────────────
#
#   concentrator-data  Named volume for session cache + auth state.
#                      Contains auth.json (passkey credentials),
#                      auth.secret (HMAC signing key), and
#                      session cache. Back this up!
#
#   web/dist           Bind mount (read-only) for frontend assets.
#                      Rebuild with: bun run build:web
